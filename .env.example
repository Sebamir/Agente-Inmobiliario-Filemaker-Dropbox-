# ============================================================
# AGENTE INMOBILIARIO - Variables de Entorno
# Copiar este archivo como .env y completar los valores reales
# NUNCA commitear el archivo .env al repositorio
# ============================================================

# --- FileMaker Data API ---
FM_URL=https://tu-servidor-filemaker.com       # URL base del servidor FileMaker (sin trailing slash)
FM_DATABASE=NombreDeTuBaseDeDatos             # Nombre exacto de la base de datos FM
FM_LAYOUT=NombreDelLayout                     # Layout de búsqueda de inmuebles
FM_USERNAME=usuario_solo_lectura              # Usuario con permisos SOLO LECTURA
FM_PASSWORD=password_seguro                   # Contraseña del usuario FM
FM_REF_FIELD=codigo_ref                       # Nombre del campo que vincula con Dropbox (ej: REF-2024-001)

# --- Dropbox ---
DROPBOX_TOKEN=sl.xxxxxxxxxxxxxxxxxxxxxx       # Access Token de la App Dropbox
DROPBOX_BASE_FOLDER=/Inmuebles                # Carpeta raíz en Dropbox donde viven los inmuebles

# --- Agente de Lenguaje Natural (OpenAI) ---
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx    # API Key de OpenAI (GPT-4o-mini)
FM_DESCRIPTION_FIELD=descripcion             # Campo FM donde buscar términos sin campo exacto

# --- Seguridad / Red Privada ---
ALLOWED_CIDR=0.0.0.0/0                       # Dev: permite todo. Prod: ej. 192.168.1.0/24
ALLOWED_ORIGIN=http://localhost:8501         # Origen permitido para CORS

# --- FastAPI ---
API_HOST=0.0.0.0
API_PORT=8000
API_DEBUG=false                               # true solo en desarrollo

# --- Streamlit ---
STREAMLIT_PORT=8501
API_BASE_URL=http://localhost:8000            # URL del backend FastAPI (desde la perspectiva de Streamlit)
